

function [] = testAdaptMeshToMetric(testCase)

    switch testCase
        case 1
            test1();
        case 2
            test2();
        case 3
            test3();
    end

end


function [] = test1()

    load('test0');

    [Xh,Th] = adapt(X,T,h);

    figure(1)
    plot(Xh(:,1),Xh(:,2),'*')

end

function [] = test2()

    maxIt = 7;

    X = [0 0; 1 0; 1 1; 0 1];
    T = [1 2 4; 2 3 4];

    it=0;
    converged = false;
    while(it<maxIt || converged==false)
        
        h = hTest2(X);
        [X,T] = adapt(X,T,h);

        it = it+1;
%         converged = checkTest2(X,T);
        converged = false;
        
        figure(1)
        clf
        plot(X(:,1),X(:,2),'r*')
        hold on
        plotMesh(X,T,0)
    end

end

function [h] = hTest2(x)
    h = 0.0001 + abs(x(:,1)x(:,2) ;
end


function [] = test3()

    load('test3');

    
    [Xh,Th] = adapt(X,T,h);

    figure(1)
    plot(X(:,1),X(:,2),'r*')
    hold on
    plotMesh(Xh,Th,0)
end






